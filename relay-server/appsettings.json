{
  "ConnectionStrings": {
    "Default": "Data Source=/config/relay.db"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "ExpiryDays": 30
  },
  "Transcode": {
    "CacheDir": "/config/transcode-cache",
    "Encoder": "auto"
  },
  "Whisper": {
    "Url": "http://whisper:9000"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:5000"
}
