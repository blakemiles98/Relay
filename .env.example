# Path to your media files on the host machine
MEDIA_PATH=/mnt/media

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# Transcode encoder: auto, h264_nvenc (NVIDIA), h264_amf (AMD), libx264 (CPU)
# auto = detected at startup from ffmpeg -encoders output
ENCODER=auto

# Whisper model size: tiny, base, small, medium, large
# Larger = more accurate subtitles, slower, more RAM. base is a good default.
WHISPER_MODEL=base

# Public URL of the backend API (as seen by the browser, for Tailscale setups)
# Only needed if accessing from outside the Docker network
# API_URL=http://your-tailscale-hostname:5000
